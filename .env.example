# ==============================================
# SUPABASE (obligatoire)
# ==============================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ==============================================
# STORAGE PROVIDER : 'supabase' (défaut) ou 's3'
# ==============================================
STORAGE_PROVIDER=supabase

# ==============================================
# BUCKET SUPABASE (un seul bucket, dossiers à l'intérieur)
# Structure : site-epreuves/epreuves/, site-epreuves/photos-profil/, site-epreuves/contributions/
# ==============================================
SUPABASE_BUCKET=site-epreuves

# ==============================================
# AWS S3 (uniquement si STORAGE_PROVIDER=s3)
# Même structure : un seul bucket avec dossiers
# ==============================================
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=site-epreuves
AWS_CLOUDFRONT_URL=

# ==============================================
# APPLICATION
# ==============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=
